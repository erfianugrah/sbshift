{
  "name": "supabase-region-migrate",
  "version": "0.1.0",
  "description": "Typed CLI orchestrator for cross-region Supabase project migration via logical replication.",
  "type": "module",
  "bin": {
    "sbmigrate": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "test:integration": "bash scripts/test-integration.sh",
    "typecheck": "tsc --noEmit",
    "check": "biome check --write .",
    "lint": "biome check ."
  },
  "dependencies": {
    "commander": "^14.0.0",
    "postgres": "^3.4.7",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
