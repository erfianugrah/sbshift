# DIRECT connections (port 5432, db.<ref>.supabase.co) — NOT the pooler.
# Logical replication setup requires a direct connection; the target also needs
# IPv6 reachability to the source (or the IPv4 add-on on the source project).
SOURCE_DB_URL="postgresql://postgres:PASSWORD@db.aaaaaaaaaaaaaaaaaaaa.supabase.co:5432/postgres"
TARGET_DB_URL="postgresql://postgres:PASSWORD@db.bbbbbbbbbbbbbbbbbbbb.supabase.co:5432/postgres"

# Supabase personal access token — only needed for `config-sync`.
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN="sbp_..."

# OPTIONAL: run pgshift from a host WITHOUT IPv6 to the direct hosts.
# Point SOURCE_DB_URL / TARGET_DB_URL at the IPv4 SESSION pooler (port 5432,
# user postgres.<ref>@aws-<n>-<region>.pooler.supabase.com) for pgshift's own
# admin/seed/reconcile queries, and set SOURCE_REPLICATION_URL to the source
# DIRECT host. The subscription's CONNECTION uses SOURCE_REPLICATION_URL, which
# the TARGET's walreceiver dials over Supabase's internal network (IPv6) — so it
# works even though your box can't reach the direct host. The pooler can NOT
# stream WAL, which is why the subscription must use the direct host.
# Verified live: the full pipeline ran this way from a non-IPv6 host.
# SOURCE_DB_URL="postgresql://postgres.aaaaaaaaaaaaaaaaaaaa:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"
# TARGET_DB_URL="postgresql://postgres.bbbbbbbbbbbbbbbbbbbb:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
# SOURCE_REPLICATION_URL="postgresql://postgres:PASSWORD@db.aaaaaaaaaaaaaaaaaaaa.supabase.co:5432/postgres"
