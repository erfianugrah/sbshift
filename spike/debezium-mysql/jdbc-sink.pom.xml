<?xml version="1.0" encoding="UTF-8"?>
<!-- Resolves the Debezium Server JDBC sink + its transitive deps + the Postgres driver.
     SPIKE FINDING: the standard quay.io/debezium/server image bundles 14 sinks (kafka,
     kinesis, pubsub, redis, …) but NOT debezium-server-jdbc. pgshift's production
     DebeziumEngine image must add the sink jars + target driver itself. This pom IS that
     manifest. -->
<project xmlns="http://maven.apache.org/POM/4.0.0">
  <modelVersion>4.0.0</modelVersion>
  <groupId>dev.pgshift</groupId>
  <artifactId>dbz-jdbc-sink-deps</artifactId>
  <version>1.0</version>
  <packaging>pom</packaging>
  <dependencies>
    <dependency>
      <groupId>io.debezium</groupId>
      <artifactId>debezium-server-jdbc</artifactId>
      <version>3.6.0.Beta2</version>
    </dependency>
    <dependency>
      <groupId>org.postgresql</groupId>
      <artifactId>postgresql</artifactId>
      <version>42.7.4</version>
    </dependency>
  </dependencies>
</project>
